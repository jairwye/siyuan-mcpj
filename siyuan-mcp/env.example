# 说明：
# 1) 本文件是变量参考模板，不是当前主流程的必需文件。
# 2) 当前主流程可直接在 mcp-internal.json / mcp-external.json 中写入 SIYUAN_* 与可选 EXA_*。
# 3) 若你希望统一管理变量，再将本文件内容复制到 ~/.mcpo/.env 使用。
# 4) 建议使用 openssl rand -hex 32 生成 API key。
#
# -----------------------------
# mcpo internal（推荐默认）
# -----------------------------
MCPO_INTERNAL_PORT=8100
MCPO_INTERNAL_API_KEY=replace-with-a-long-random-key

# -----------------------------
# external（默认禁用，需要时再启用）
# -----------------------------
# MCPO_EXTERNAL_PORT=8200
# MCPO_EXTERNAL_API_KEY=replace-with-a-long-random-key

# -----------------------------
# siyuan-mcpj 连接思源
# -----------------------------
# 思源内核 API 地址（可为 127.0.0.1、思源容器名或内网地址）
SIYUAN_HOST=127.0.0.1
# 思源 API 端口
SIYUAN_PORT=6806
# 思源 API 令牌（必填）：思源 -> 设置 -> 关于 -> API 令牌
SIYUAN_TOKEN=
# 请求超时（毫秒）
SIYUAN_TIMEOUT_MS=15000

# -----------------------------
# 外部实例可选变量（示例，external 启用时才需要）
# -----------------------------
# EXA_API_KEY=
